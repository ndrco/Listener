#!/usr/bin/env python3
"""Disable Listener spoken replies via the bundled listener-control helper."""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def _run(helper: Path, args: list[str]) -> int:
    return subprocess.call([sys.executable, str(helper), *args])


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    helper = (
        Path(__file__).resolve().parents[2]
        / "listener-control"
        / "scripts"
        / "listener-control"
    )
    if not helper.is_file():
        print(
            f"error: listener-control helper not found at {helper}",
            file=sys.stderr,
        )
        return 1

    command = ["speaker", "off", *args]
    if "--reason" not in args:
        command.extend(["--reason", "disable spoken replies"])

    status = _run(helper, command)
    if status != 0:
        return status
    return _run(helper, ["speaker", "status"])


if __name__ == "__main__":
    raise SystemExit(main())
